FROM node:18-alpine
WORKDIR /app
ENV NODE_ENV=production
# Amazon DocumentDB requires TLS by default. This bundle is used when MONGODB_URI includes tlsCAFile=/app/global-bundle.pem
RUN apk add --no-cache ca-certificates wget   && wget -q -O /app/global-bundle.pem https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
COPY package*.json ./
RUN npm install --omit=dev
COPY . .
EXPOSE 3003
CMD ["node", "server.js"]
