# Root-level defaults used by docker-compose.yml
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_PORT=8080
API_GATEWAY_PORT=3000
MONGODB_PORT=27017

# Optional SMTP for notification-service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Flipkart Clone <no-reply@example.com>"
